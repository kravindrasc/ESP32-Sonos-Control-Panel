# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# IP address of any one of your Sonos speakers.
# Find it in the Sonos app → Settings → System → About My System,
# or check your router's connected-devices / DHCP table.
SONOS_PLAYER_IP=192.168.1.xxx

# Port the bridge server listens on (must match USER_BRIDGE_BASE in user_config.h)
PORT=3000
